<!-- Views/Juegos/Delete.cshtml -->
@model api_gamezone.Entities.Juego

@{
    ViewData["Title"] = "Eliminar Juego";
}

<h2>¿Eliminar este juego?</h2>

<div class="card mt-3" style="max-width:400px">
    <div class="card-body">
        <p><strong>Título:</strong> @Model.Titulo</p>
        <p><strong>Género:</strong> @Model.Genero</p>
        <p><strong>Precio:</strong> @Model.Precio.ToString("C")</p>
    </div>
</div>

<form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="mt-3">
    @Html.AntiForgeryToken()
    <button type="submit" class="btn btn-danger">Confirmar eliminación</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
</form>