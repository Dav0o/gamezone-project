@using api_gamezone.Entities
<!-- Views/Juegos/Index.cshtml -->
@model IEnumerable<Juego>

@{
    ViewData["Title"] = "Juegos";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Catálogo de Juegos</h2>
    <a asp-action="Create" class="btn btn-primary">+ Nuevo juego</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Título</th>
            <th>Género</th>
            <th>Precio</th>
            <th>Disponible</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var juego in Model)
        {
            <tr>
                <td>@juego.Titulo</td>
                <td>@juego.Genero</td>
                <td>@juego.Precio.ToString("C")</td>
                <td>@(juego.Disponible ? "Sí" : "No")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@juego.Id" class="btn btn-sm btn-warning">Editar</a>
                    <a asp-action="Delete" asp-route-id="@juego.Id" class="btn btn-sm btn-danger">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>